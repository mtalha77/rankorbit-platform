# ─── NAP ORBIT ENVIRONMENT VARIABLES ─────────────────────────────────────────
# Copy this file to `.env.local` for local dev, and set the same keys in Vercel
# (Settings → Environment Variables) for production. NEVER commit real values.
#
# VITE_* variables are exposed to the browser (frontend). Only put PUBLIC keys here.
# Non-VITE variables are server-only (used by /api serverless functions) and are SECRET.

# ── Frontend (public, safe to expose) ────────────────────────────────────────
# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon / publishable key (public by design; RLS protects the data)
VITE_SUPABASE_ANON_KEY=

# Show demo quick-fill login buttons. Set to "false" at go-live to hide them.
VITE_SHOW_DEMOS=true

# ── Serverless functions (SECRET, server-only, never prefix with VITE_) ───────
# Supabase service-role key. Full admin access, used by /api/create-staff.
# Get it from Supabase → Project Settings → API Keys → service_role (secret).
# Use the COPY ICON, not manual selection, to avoid stray characters.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe secret key (live or test), used by /api/stripe-webhook.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (starts with whsec_), used to verify webhook events.
STRIPE_WEBHOOK_SECRET=

# Resend (client + staff email notifications). Optional — in-app notifications work without these.
# Get API key from https://resend.com → API Keys. Verify your sending domain first for production.
RESEND_API_KEY=
# e.g. NAP Orbit <noreply@naporbit.com>  (must match a verified Resend domain)
NOTIFY_FROM_EMAIL=
# Public app URL used in email dashboard links
APP_URL=
